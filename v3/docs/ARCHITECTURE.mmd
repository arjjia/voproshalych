graph TB
    subgraph User["Пользователь"]
        Browser["Браузер"]
        VK["ВКонтакте"]
        MaxChat["Max (OnlinePatrol)"]
    end

    subgraph Frontend["Frontend"]
        LobeChat["LobeChat v3 (:3210)<br/>Кастомный fork<br/>Auth email+password<br/>#00aeef + pixel cat"]
    end

    subgraph AgentService["Agent Service (:8001)"]
        FastAPI["FastAPI<br/>v1/chat/completions v1/models<br/>v1/embeddings /chat /health<br/>/trace /mcp/tools"]
        MW["UserIdentityMiddleware<br/>X-User-Id / X-User-Role"]
        LangGraph["LangGraph граф"]
        Supervisor["Supervisor<br/>Классификатор интентов"]
        KB_Workflow["KB Workflow<br/>Поиск по БЗ → LLM"]
        Meta["Meta<br/>Ответы про ассистента"]
        ReAct["ReAct<br/>Multi-tool MCP агент"]
        Clarify["Clarify<br/>Уточнение запроса"]
        OffTopic["Off-Topic<br/>Вежливый отказ"]
        MCP_Client["MCP-клиент<br/>HTTP JSON-RPC"]
        Dialog["Dialog Context<br/>История диалога"]
        Traces["trace_logger<br/>JSON Lines"]

        FastAPI --> MW
        MW --> LangGraph
        MW --> Traces
        LangGraph --> Dialog
        Dialog --> Supervisor
        Supervisor -->|kb_qa| KB_Workflow
        Supervisor -->|meta| Meta
        Supervisor -->|tool_required| ReAct
        Supervisor -->|clarify| Clarify
        Supervisor -->|off_topic| OffTopic
        KB_Workflow --> END["END"]
        Meta --> END
        ReAct --> END
        Clarify --> END
        OffTopic --> END

        FastAPI --> MCP_Client
    end

    subgraph LLM["LiteLLM Gateway (:4000)"]
        LiteLLM["LiteLLM Proxy<br/>~15 моделей"]
        Primary["deepseek-v4-flash-free<br/>OpenCode Zen<br/>Основная"]
        Fallback_Free["nemotron-ultra-free<br/>hy3-free | mimo-free<br/>llama-70b-or | qwen-coder-or<br/>Free fallback chain"]
        Fallback_Light["glm-5.2 | mistral-nemo<br/>Light fallback chain"]
        Classifier_LLM["nemotron-ultra-free<br/>t=0.1, max_tokens=512<br/>Классификация"]
        Embed_LLM["mistral-embed<br/>dim=1024<br/>Эмбеддинги для API"]
        Redis_Cache["Redis Cache<br/>TTL: 3600с"]

        LiteLLM --> Primary
        LiteLLM --> Fallback_Free
        LiteLLM --> Fallback_Light
        LiteLLM --> Classifier_LLM
        LiteLLM --> Embed_LLM
        LiteLLM --> Redis_Cache
    end

    subgraph KnowledgeBase["База знаний"]
        KB_Service["kb-service (:8005)<br/>FastAPI JSON-RPC"]
        LocalEmbed["SentenceTransformer<br/>deepvk/USER-bge-m3<br/>Локально, dim=1024"]
        PGVector["PostgreSQL + pgvector<br/>Chunk → Embedding → Search"]
        Parsers["Парсеры<br/>WebPageParser UtmnParser<br/>UtmnNewsParser SvedenParser<br/>FaqParser ConfluenceParser"]

        KB_Service --> LocalEmbed
        KB_Service --> PGVector
        KB_Service --> Parsers
    end

    subgraph MCP_Servers["MCP-серверы"]
        MCP_KB["mcp-kb (:9010)<br/>Bridge to kb-service"]
        MCP_News["mcp-news (:9011)<br/>FastMCP<br/>get_news / get_events"]
        MCP_Fetch["mcp-fetch (:9015)<br/>FastMCP<br/>fetch_url"]
        MCP_Contacts["mcp-contacts (:9012)<br/>FastMCP<br/>search_contacts"]
        MCP_Library["mcp-library (:9013)<br/>FastMCP<br/>library info"]
        MCP_Sveden["mcp-sveden (:9014)<br/>FastMCP<br/>sveden info"]
    end

    subgraph External["Внешние источники данных"]
        UTMN_News["utmn.ru/news/stories<br/>Новости"]
        UTMN_Events["utmn.ru/news/events<br/>События"]
        UTMN_Contacts["utmn.ru/kontakty/<br/>Контакты"]
        BMK["bmk.utmn.ru<br/>lib.utmn.ru<br/>Библиотека"]
        SVEDEN["sveden.utmn.ru<br/>Сведения об организации"]
        CONFLUENCE["Confluence<br/>Help + Study"]
    end

    subgraph Infrastructure["Инфраструктура"]
        Redis["Redis 7 (:6380)"]
        PG["PostgreSQL (:5433)<br/>pgvector + AGE"]
    end

    subgraph Bots["Боты"]
        BotVK["bot-vk<br/>ВКонтакте бот"]
        BotMax["bot-max<br/>Max бот"]
    end

    %% Connections — Frontend
    Browser -->|"OpenAI API"| LobeChat
    LobeChat -->|v1/chat/completions| FastAPI
    LobeChat -->|AUTH_DATABASE_URL| PG

    %% Connections — Bots
    VK --> BotVK
    MaxChat --> BotMax
    BotVK -->|HTTP| FastAPI
    BotMax -->|HTTP| FastAPI

    %% Connections — LLM calls
    Supervisor -.->|classifier| LiteLLM
    KB_Workflow -.->|LLM call| LiteLLM
    ReAct -.->|LLM call| LiteLLM
    Meta -.->|LLM call| LiteLLM

    %% Connections — MCP
    MCP_Client -->|tools/list & tools/call| MCP_KB
    MCP_Client -->|tools/list & tools/call| MCP_News
    MCP_Client -->|tools/list & tools/call| MCP_Fetch
    MCP_Client -->|tools/list & tools/call| MCP_Contacts
    MCP_Client -->|tools/list & tools/call| MCP_Library
    MCP_Client -->|tools/list & tools/call| MCP_Sveden

    %% Connections — External data
    MCP_KB -->|JSON-RPC| KB_Service
    MCP_News -->|HTTP| UTMN_News
    MCP_News -->|HTTP| UTMN_Events
    MCP_Fetch -->|HTTP| UTMN_News
    MCP_Fetch -->|HTTP| UTMN_Events
    MCP_Contacts -->|HTTP| UTMN_Contacts
    MCP_Library -->|HTTP| BMK
    MCP_Sveden -->|HTTP| SVEDEN
    KB_Service -->|Confluence parser| CONFLUENCE

    %% Connections — Infra
    KB_Service -->|pgvector| PG
    LiteLLM -->|cache| Redis
    LiteLLM -->|model usage| PG

    %% Стили — каждый компонент своим цветом
    classDef frontend fill:#00bcd4,color:#fff,stroke:#0097a7
    classDef agent fill:#1a73e8,color:#fff,stroke:#1557b0
    classDef llm fill:#ea4335,color:#fff,stroke:#c5221f
    classDef kb fill:#ff6f00,color:#fff,stroke:#e65100
    classDef embedding fill:#8e24aa,color:#fff,stroke:#6a1b9a
    classDef mcp fill:#34a853,color:#fff,stroke:#2d8f47
    classDef mcp_new fill:#0d8043,color:#fff,stroke:#095e31
    classDef external fill:#fbbc04,color:#333,stroke:#e8a800
    classDef infra fill:#9c27b0,color:#fff,stroke:#7b1fa2
    classDef user fill:#607d8b,color:#fff,stroke:#455a64
    classDef end_node fill:#78909c,color:#fff,stroke:#546e7a
    classDef bots fill:#00897b,color:#fff,stroke:#00695c
    classDef traces fill:#7986cb,color:#fff,stroke:#5c6bc0
    classDef middleware fill:#e64a19,color:#fff,stroke:#bf360c
    classDef auth fill:#d81b60,color:#fff,stroke:#880e4f

    class LobeChat frontend
    class FastAPI,LangGraph,Supervisor,KB_Workflow,Meta,ReAct,Clarify,OffTopic,Dialog agent
    class MW middleware
    class LiteLLM,Primary,Fallback_Free,Fallback_Light,Classifier_LLM llm
    class Embed_LLM embedding
    class KB_Service,Parsers,PGVector kb
    class LocalEmbed embedding
    class MCP_KB,MCP_News,MCP_Contacts,MCP_Library,MCP_Sveden mcp
    class MCP_Fetch mcp_new
    class UTMN_News,UTMN_Events,UTMN_Contacts,BMK,SVEDEN,CONFLUENCE external
    class Redis,Redis_Cache,PG infra
    class Browser,VK,MaxChat user
    class END end_node
    class BotVK,BotMax bots
    class Traces traces
