# LightRAG Server (WebUI)
# Скопировать как .env.lightrag и заполнить значения

# Server
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE=Voproshalych Knowledge Graph
WEBUI_DESCRIPTION=Граф знаний Вопрошалыча

# Storage — PostgreSQL (та же что и у qa-service)
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=voproshalych
POSTGRES_PASSWORD=voproshalych
POSTGRES_DATABASE=voproshalych

# LLM — Ollama (удалённый сервер для индексации)
LLM_BINDING=ollama
LLM_BINDING_HOST=http://iv-fc.orienteer.ru:12434
LLM_MODEL=qwen3.6:35b

# Embedding — Mistral API
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.mistral.ai/v1
EMBEDDING_MODEL=mistral-embed
EMBEDDING_DIM=1024
EMBEDDING_BINDING_API_KEY=<MISTRAL_API_KEY>
