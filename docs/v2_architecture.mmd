%%{
  init: {
    'theme': 'base',
    'themeVariables': {
      'background': '#011B3A',
      'primaryColor': '#032B50',
      'primaryTextColor': '#FFFFFF',
      'primaryBorderColor': '#046CE0',
      'lineColor': '#FFFFFF',
      'secondaryColor': '#021E39',
      'tertiaryColor': '#021E39',
      'clusterBkg': '#011B3A',
      'clusterBorder': '#0357D2',
      'nodeBorder': '#046CE0',
      'nodeTextColor': '#FFFFFF',
      'edgeLabelBackground': '#032B50',
      'edgeLabelColor': '#FFFFFF',
